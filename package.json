{
  "name": "yxorp",
  "version": "0.2.0",
  "description": "Yxorp is a reverse proxy for rewriting or mocking API data.",
  "main": "dist/index.js",
  "bin": {
    "yxorp": "bin/yxorp.js"
  },
  "scripts": {
    "start": "nodemon src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Kirill Suntsov",
  "license": "MIT",
  "dependencies": {
    "http-encoding": "^2.2.0",
    "httpxy": "^0.5.3",
    "mime": "^3.0.0",
    "path-to-regexp": "^8.4.2",
    "qs": "^6.15.2",
    "tslib": "^2.8.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/mime": "^3.0.4",
    "@types/node": "^20.19.41",
    "@types/qs": "^6.15.1",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">= 18"
  }
}
