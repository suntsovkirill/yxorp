{
  "name": "yxorp",
  "version": "0.3.0",
  "description": "A local reverse proxy for rewriting, mocking, and debugging API responses.",
  "keywords": [
    "reverse-proxy",
    "proxy",
    "http-proxy",
    "mock",
    "mock-server",
    "api-mock",
    "rewrite",
    "http",
    "api",
    "debugging",
    "cli",
    "developer-tools"
  ],
  "files": [
    "dist/",
    "bin/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "dist/index.js",
  "bin": {
    "yxorp": "bin/yxorp.js"
  },
  "scripts": {
    "start": "nodemon src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Kirill Suntsov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suntsovkirill/yxorp.git"
  },
  "bugs": {
    "url": "https://github.com/suntsovkirill/yxorp/issues"
  },
  "homepage": "https://github.com/suntsovkirill/yxorp#readme",
  "dependencies": {
    "http-encoding": "^2.2.0",
    "httpxy": "^0.5.3",
    "mime": "^3.0.0",
    "path-to-regexp": "^8.4.2",
    "qs": "^6.15.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/mime": "^3.0.4",
    "@types/node": "^20.19.41",
    "@types/qs": "^6.15.1",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">= 20"
  }
}
